# -----------------------------------------------------------------------------
# UAT / PRD 欄位對照模板（UAT 現有值已在上方）
# -----------------------------------------------------------------------------
# 你的程式會依 NODE_ENV 自動切換：
# - NODE_ENV=development / test  => 優先讀 *_UAT，若無則讀一般 NEXT_PUBLIC_FIREBASE_*
# - NODE_ENV=production          => 優先讀 *_PRD，若無則讀一般 NEXT_PUBLIC_FIREBASE_*
#
# 建議做法：
# 1) .env（本檔）維持 UAT（已完成）
# 2) .env.production 放 PRD 值（部署正式環境使用）
#
# [UAT 既有欄位（已存在）]                -> [PRD 對應欄位]
# NEXT_PUBLIC_FIREBASE_API_KEY            -> NEXT_PUBLIC_FIREBASE_API_KEY_PRD
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN        -> NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_PRD
# NEXT_PUBLIC_FIREBASE_PROJECT_ID         -> NEXT_PUBLIC_FIREBASE_PROJECT_ID_PRD
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET     -> NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_PRD
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID-> NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_PRD
# NEXT_PUBLIC_FIREBASE_APP_ID             -> NEXT_PUBLIC_FIREBASE_APP_ID_PRD
#
# -----------------------------------------------------------------------------
# 建議貼到 .env.production 的 PRD 模板（請填入正式環境值）
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FIREBASE_API_KEY_PRD=""
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_PRD=""
# NEXT_PUBLIC_FIREBASE_PROJECT_ID_PRD=""
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_PRD=""
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_PRD=""
# NEXT_PUBLIC_FIREBASE_APP_ID_PRD=""
#
# Emulator 控制（重要）
# - production 嚴禁使用 emulator（程式已防呆）
# - UAT 若要用 emulator 才設 true；否則 false 或不設
# NEXT_PUBLIC_FIREBASE_USE_EMULATOR=false
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
# NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_HOST=127.0.0.1
# NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
#


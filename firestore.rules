rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn() && userDoc().data != null;
    }

    function isAdmin() {
      return userExists() && userDoc().data.role.lower() == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // 分開 allow read，避免 OR 導致 Admin 的 collection 查詢（無 userId 過濾）遭拒
    match /reservations/{reservationId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow write: if false;
    }

    match /temporaryAccess/{docId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /temporaryAccessRequests/{docId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /temporaryAccessSegments/{docId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /roomSettings/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /globalSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 網站公告：登入前頂部欄需公開讀取；已登入用戶亦可讀取比對角色
    match /settings/notifications {
      allow read: if true;
      allow write: if false;
    }

    match /tokenRequests/{docId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow write: if false;
    }

    match /_connection_test_/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /blockedSlots/{dateId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}

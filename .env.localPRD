# --- Nodemailer (後台發送 QR Code 郵件用) ---
# 用於代表您發送郵件給使用者。推薦使用 Gmail。
# 如果使用 Gmail，您需要在您的 Google 帳戶中建立一個「應用程式密碼」。

# 您的郵件服務器地址 (例如: "smtp.gmail.com")
EMAIL_SERVER_HOST="smtp.gmail.com"

# 您的郵件服務器端口 (例如: 587)
EMAIL_SERVER_PORT="587"

# 您用來發送郵件的完整電郵地址 (例如: "your-email@gmail.com")
EMAIL_SERVER_USER="snookerkingdombooking@gmail.com"

# 您為此應用程式產生的「應用程式密碼」，而非您的帳戶登入密碼。
EMAIL_SERVER_PASSWORD="yiwm ycbm vvzf vmic"

# 您希望在郵件中顯示的寄件人名稱 (例如: "Snooker Kingdom Booking")
EMAIL_FROM_NAME="Snooker Kingdom"

